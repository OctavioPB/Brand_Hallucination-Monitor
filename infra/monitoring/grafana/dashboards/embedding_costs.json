{
  "title": "hallucin8 — Embedding Costs & Budget",
  "uid": "hallucin8-embedding-costs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "org_id",
        "type": "query",
        "query": "label_values(hallucin8_embedding_cost_usd_total, org_id)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Today's Total Spend (USD)",
      "description": "Cumulative embedding API spend today across all orgs.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3.0 },
              { "color": "red", "value": 4.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(hallucin8_daily_spend_usd{org_id=~\"$org_id\"})",
          "legendFormat": "total spend"
        }
      ]
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Budget Used (%)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(hallucin8_daily_spend_usd) / 5.0 * 100",
          "legendFormat": "budget %"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Circuit Breaker States",
      "description": "0=CLOSED (healthy), 1=HALF_OPEN, 2=OPEN (blocked)",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "hallucin8_circuit_breaker_state",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cumulative Spend Rate (USD/hour) by Org",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(hallucin8_embedding_cost_usd_total{org_id=~\"$org_id\"}[1h]) * 3600",
          "legendFormat": "{{org_id}} / {{job_type}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "API Request Latency P95 (ms)",
      "description": "95th percentile latency for all API endpoints.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 150 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler)) * 1000",
          "legendFormat": "P95 {{handler}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP Error Rate (4xx + 5xx / min)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{status=~\"4..|5..\"}[1m])) by (status)",
          "legendFormat": "HTTP {{status}}"
        }
      ]
    }
  ]
}
