# ============================================================
# hallucin8 — environment variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local or any file with real secrets.
# ============================================================

# ------------------------------------------------------------------
# API Keys (required)
# ------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# Optional LLM probers (Sprint 5)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------
POSTGRES_USER=hallucin8
POSTGRES_PASSWORD=hallucin8
POSTGRES_DB=hallucin8
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://hallucin8:hallucin8@localhost:5432/hallucin8
DATABASE_URL_SYNC=postgresql+psycopg2://hallucin8:hallucin8@localhost:5432/hallucin8

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------------------------------------------------------------------
# Qdrant
# ------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ------------------------------------------------------------------
# Neo4j
# ------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=hallucin8pass

# ------------------------------------------------------------------
# Kafka / Redpanda
# ------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ------------------------------------------------------------------
# Auth (Supabase — Sprint 6)
# ------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=change-me-in-production

# ------------------------------------------------------------------
# App settings
# ------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=DEBUG
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Maximum daily spend cap for LLM probing (USD)
MAX_DAILY_SPEND_USD=5.00

# ------------------------------------------------------------------
# Sprint 8 — Alerts & Reports
# ------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@hallucin8.io
SLACK_WEBHOOK_URL=
ALERT_RULE_COOLDOWN_MINUTES=60

# ------------------------------------------------------------------
# Sprint 9 — Observability
# ------------------------------------------------------------------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
GCS_BACKUP_BUCKET=
GCS_BACKUP_PREFIX=hallucin8/backups
PROBE_DAILY_MODEL=gpt-4o-mini
PROBE_WEEKLY_MODEL=gemini-1.5-pro

# ------------------------------------------------------------------
# Sprint 10 — Beta Launch
# ------------------------------------------------------------------
# Internal admin panel — set to a strong random value in production
ADMIN_SECRET=change-me-admin-secret
# PostHog project API key (https://app.posthog.com)
POSTHOG_API_KEY=
# GitHub personal access token for automatic UI error reporting
GITHUB_ISSUE_TOKEN=
# Intercom app ID (from Intercom workspace settings)
INTERCOM_APP_ID=

# Next.js public env vars (accessible in browser — no secrets)
NEXT_PUBLIC_ADMIN_SECRET=change-me-admin-secret
NEXT_PUBLIC_INTERCOM_APP_ID=
NEXT_PUBLIC_POSTHOG_API_KEY=
NEXT_PUBLIC_GITHUB_ISSUE_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
